# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-...
OPENAI_MODEL=openai/gpt-5.4-mini

# Optional: lock down the FastAPI endpoint with a secret header
ALPHAWALKER_API_KEY=

# Insforge cloud database — enables the History tab and cross-session caching
# Get these from your Insforge project settings
INSFORGE_URL=https://your-project.us-east.insforge.app
INSFORGE_SERVICE_KEY=your-anon-key
